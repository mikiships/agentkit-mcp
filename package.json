{
  "name": "agentkit-mcp",
  "version": "0.1.0",
  "description": "MCP server exposing coderace, agentmd, agentlint, and agentreflect as tools for Claude Code and MCP clients",
  "main": "dist/index.js",
  "bin": {
    "agentkit-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "claude",
    "agentmd",
    "agentlint",
    "agentreflect",
    "coderace",
    "agent-quality",
    "claude-code"
  ],
  "author": "mikiships",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mikiships/agentkit-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/mikiships/agentkit-mcp/issues"
  },
  "homepage": "https://github.com/mikiships/agentkit-mcp#readme"
}
